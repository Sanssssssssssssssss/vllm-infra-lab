# Copy this file to config/runtime.env before starting the service.

# Active profile. Switch with scripts/set_active_profile.ps1 when needed.
ACTIVE_PROFILE=qwen3_8b_gguf_q4_k_m

# Shared OpenAI-style API settings.
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=change-this-before-lan-use

# Keep the existing vLLM variables for backward compatibility with WSL scripts.
VLLM_MODEL=/mnt/e/GPTProject2/models/Qwen3-8B
VLLM_SERVED_MODEL_NAME=Qwen3-8B-local
VLLM_DTYPE=half
VLLM_MAX_MODEL_LEN=2048
VLLM_HOST=0.0.0.0
VLLM_PORT=8000
VLLM_API_KEY=change-this-before-lan-use
VLLM_GPU_MEMORY_UTILIZATION=0.80
VLLM_MAX_NUM_SEQS=1
VLLM_CPU_OFFLOAD_GB=10
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_ENFORCE_EAGER=1

# Optional cache location inside WSL.
HF_HOME=/mnt/e/GPTProject2/hf-cache
HF_HUB_DISABLE_XET=1
