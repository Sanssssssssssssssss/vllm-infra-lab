# Profile: keep the existing WSL + vLLM baseline available.

PROFILE_ID=qwen3_8b_vllm
BACKEND=vllm
PROFILE_DESCRIPTION=WSL2 plus vLLM baseline for Qwen3-8B

MODEL_FAMILY=Qwen
MODEL_ID=Qwen/Qwen3-8B
SERVED_MODEL_NAME=Qwen3-8B-local

VLLM_MODEL=/mnt/e/GPTProject2/models/Qwen3-8B
